{
  "name": "vue-pair-programming-test",
  "version": "1.0.0",
  "description": "A simple Vue.js application for pair programming tests.",
  "main": "src/main.js",
  "scripts": {
    "dev": "vite --mode localhost --host",
    "build": "rm -rf dist && npm run check-typing && vite build",
    "preview": "vite preview --host",
    "check-typing": "vue-tsc --build --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "jsdom": "^29.0.2",
    "sass-embedded": "^1.98.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.5"
  },
  "keywords": [],
  "author": "",
  "license": "MIT"
}
